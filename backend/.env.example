# data-tool-mcp 后端环境变量示例
# 复制为 .env 并按实际环境修改。所有变量均可通过 CLI 参数覆盖(--foo-bar 对应 FOO_BAR)。

# ============================================================================
# 配置持久化存储
# ============================================================================

# SQLite 文件路径(仅 --prebuilt sqlite 时使用,默认 toolbox_data.db)
# SQLITE_DATABASE=/data/toolbox_data.db

# 配置持久化存储 URL(留空=默认 SQLite 文件;MySQL 推荐 mysql://host:port/db,不含账号密码)
DATA_TOOL_MCP_STORE_URL=mysql://127.0.0.1:3306/data_tool_mcp

# 配置持久化存储 MySQL 凭据(与 URL 分离,避免凭据泄露在 URL/日志中)
DATA_TOOL_MCP_STORE_USERNAME=root
# DATA_TOOL_MCP_STORE_PASSWORD 必须为密文(使用 encrypt_password 命令生成)
# 示例: python -m data_tool_mcp.cli.main encrypt-password
DATA_TOOL_MCP_STORE_PASSWORD=

# 数据库连接池大小(默认 5;多实例部署时按 实例数×pool_size×数据源数 估算 MySQL max_connections)
# DATA_TOOL_MCP_DB_POOL_SIZE=5
# DATA_TOOL_MCP_DB_MAX_OVERFLOW=10

# DB 配置热重载轮询间隔(秒,默认 5)
# DATA_TOOL_MCP_RELOAD_INTERVAL=5

# ============================================================================
# 加密
# ============================================================================

# Fernet 加密密钥(urlsafe-base64 编码的 32 字节)
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 生产模式(监听 0.0.0.0 或 APP_ENV=production)下必须配置,否则启动会 fail-fast
DATA_TOOL_MCP_ENCRYPTION_KEY=

# SM4 国密加密密钥(仅当 utils/crypto.py 替换为 SM4 实现时使用,16 字节)
# DATA_TOOL_MCP_SM4_KEY=

# ============================================================================
# 运行模式
# ============================================================================

# 生产模式标志(监听 0.0.0.0 或 APP_ENV=production 时启用强制安全检查)
# APP_ENV=production

# 日志级别: DEBUG / INFO / WARN / ERROR
# DATA_TOOL_MCP_LOG_LEVEL=INFO
# 日志格式: standard / json(json 适合 ELK/Loki 等日志聚合系统)
# DATA_TOOL_MCP_LOGGING_FORMAT=standard

# ============================================================================
# 数据源类型白名单
# ============================================================================

# 启用的数据源类型(逗号分隔,留空=全部启用)
# 内网部署建议限定为实际使用的类型,例如: postgres,mysql,redis,sqlite
# DATA_TOOL_MCP_ENABLED_SOURCE_TYPES=postgres,mysql,redis

# ============================================================================
# 预构建配置中的 ${VAR} 占位符密码映射(JSON)
# ============================================================================

# 用于预构建 YAML 配置中的 ${VAR} 占位符替换
# 示例: {"PG_PASSWORD":"xxx","MYSQL_PWD":"yyy"}
# ENV_PASSWORDS={}

# ============================================================================
# 遥测(可选,默认禁用)
# ============================================================================

# OpenTelemetry OTLP 端点(内网部署应指向内网 collector,例如 http://otel-collector:4318)
# DATA_TOOL_MCP_TELEMETRY_OTLP=
# 启用 GCP Cloud Trace/Cloud Monitoring(内网部署不要启用)
# DATA_TOOL_MCP_TELEMETRY_GCP=false
# DATA_TOOL_MCP_TELEMETRY_GCP_PROJECT=
# DATA_TOOL_MCP_TELEMETRY_SERVICE_NAME=data-tool-mcp

# ============================================================================
# 网络与安全
# ============================================================================

# 允许的 Host 头列表(防止 DNS rebinding;生产部署必须配置实际域名/IP)
# DATA_TOOL_MCP_ALLOWED_HOSTS=data-tool-mcp.internal,10.0.0.1

# 允许的 CORS 源(默认 *,生产部署应限定为前端实际域名)
# DATA_TOOL_MCP_ALLOWED_ORIGINS=https://data-tool-mcp.internal

# 全局 API Key 认证(留空=不启用;设置后所有 MCP/Admin API 请求需带 Authorization header)
# DATA_TOOL_MCP_API_KEY=
